# Copy this file to backend/.env and fill in your own values.
# Do not commit backend/.env.

# Preferred generic key name for future configurable LLM support.
LLM_API_KEY=

# Current MVP-compatible DeepSeek key name.
# If both LLM_API_KEY and DEEPSEEK_API_KEY are set, LLM_API_KEY should take priority after the runtime config work is implemented.
DEEPSEEK_API_KEY=

# Non-sensitive provider defaults. These may also come from config/app.config.json.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Increase this if complex generated apps often time out before the model finishes.
# Current MVP-compatible name:
REQUEST_TIMEOUT_SECONDS=60

# Preferred generic timeout name for future configurable LLM support.
LLM_REQUEST_TIMEOUT_SECONDS=60

# Maximum generated HTML size accepted by the backend validator.
MAX_HTML_LENGTH=80000
