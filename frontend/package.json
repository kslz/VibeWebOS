{
  "name": "vibewebos-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-config": "node scripts/sync-runtime-ui-config.mjs",
    "predev": "npm run sync-config",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "npm run sync-config",
    "build": "vue-tsc -b && vite build",
    "prelint": "npm run sync-config",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "pretest": "npm run sync-config",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "pretypecheck": "npm run sync-config",
    "typecheck": "vue-tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "pinia": "^2.3.1",
    "sass": "^1.89.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vue": "^3.5.16",
    "vue-tsc": "^2.2.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.5",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1"
  }
}
